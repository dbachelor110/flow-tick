{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "DOM",
      "ES2022"
    ],
    "paths": {
      "*": ["./*"]
    },
    "module": "es2022",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "typeRoots": ["typings"],
    "allowJs": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "importHelpers": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "isolatedModules": true
  },
  "exclude": [
    "node_modules",
    "**.mjs",
    "**.js"
  ]
}